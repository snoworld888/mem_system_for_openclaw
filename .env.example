# ── 服务器配置 ──────────────────────────────
HOST=0.0.0.0
PORT=8765
DEBUG=false

# ── 数据目录 ────────────────────────────────
DATA_DIR=./data

# ── 嵌入模型（本地运行，无需API）─────────────
# 轻量多语言模型（约420MB，首次使用自动下载）
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DEVICE=cpu

# ── LLM（可选，用于高质量摘要压缩）───────────
# 如不填，降级为规则压缩（无需API，速度更快）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
COMPRESS_MODEL=gpt-4o-mini

# ── 短期记忆参数 ─────────────────────────────
STM_MAX_TURNS=20
STM_MAX_TOKENS=1500
STM_COMPRESS_TOKENS=300
STM_KEEP_LAST=6

# ── 长期记忆参数 ─────────────────────────────
LTM_TOP_K=5
LTM_THRESHOLD=0.25

# ── 上下文组装 ──────────────────────────────
DEFAULT_MAX_TOKENS=2000
AUTO_EXTRACT_FACTS=true
